@InspectNameStyle = (FontSize: 13, TextColor: #eceff1, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center, Wrap: true);

@InspectRarityStyle = (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);

@InspectLevelStyle = (FontSize: 11, TextColor: #90a4ae, HorizontalAlignment: Start, VerticalAlignment: Center);

@InspectHpTextStyle = (FontSize: 10, TextColor: #eceff1, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);

@InspectAffixStyle = (FontSize: 10, TextColor: #b0bec5, HorizontalAlignment: Start, VerticalAlignment: Center);

Group {
  Group #MmoscalingInspectPanel {
    // Static fallback anchor only - the runtime applyConfiguredPosition (MobInspectorHud.defaultPosition)
    // always wins. Left-anchored to match: NO Horizontal here, "Horizontal: N" is a left+right inset
    // (stretch to fill minus N), so "Horizontal: 0" would stretch this to full screen width.
    Anchor: (Top: 216, Left: 16, Width: 280, Height: 108);
    LayoutMode: Left;
    Padding: (Full: 6);
    Background: #000000(0.35);

    // LEFT column: the target mob's generated portrait (Icons/ModelsGenerated/<role>.png), pushed by Java.
    // Toggled whole via .Visible; when hidden the Left layout collapses it and the info column takes the room.
    // FallbackTexturePath covers a role whose portrait was never generated.
    AssetImage #MmoscalingInspectPortrait {
      Anchor: (Width: 72, Height: 72);
      Visible: false;
      FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png";
    }

    Group #MmoscalingInspectPortraitGap { Anchor: (Width: 6); }

    // RIGHT column: name / rarity+difficulty / HP bar / affix chips.
    Group #MmoscalingInspectInfo {
      FlexWeight: 1;
      LayoutMode: Top;

      Label #MmoscalingInspectName {
        Text: "";
        Anchor: (Height: 30);
        Style: @InspectNameStyle;
      }

      Group {
        Anchor: (Height: 16);
        LayoutMode: Left;

        Label #MmoscalingInspectRarity {
          Text: "";
          Anchor: (Height: 16);
          Padding: (Right: 8);
          Style: @InspectRarityStyle;
        }

        Label #MmoscalingInspectLevel {
          Text: "";
          Anchor: (Height: 16);
          Style: @InspectLevelStyle;
        }
      }

      // Fixed width so the Java-pushed fill (a fixed 188 = 190 - 2 pad) always fills the BAR exactly,
      // independent of the info column width (which widens when the portrait column is hidden). The bar
      // then stays 190 left-aligned rather than stretching to the column edge.
      Group #MmoscalingInspectHpBg {
        Anchor: (Width: 190, Height: 14);
        Padding: (Full: 1);
        Background: #000000(0.6);

        Group #MmoscalingInspectHpFill {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 0);
          Background: #c94f4f;
        }

        Label #MmoscalingInspectHp {
          Text: "";
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Style: @InspectHpTextStyle;
        }
      }

      // Affix chips wrap onto a second line. Each chip is a fixed-width icon + name so the wrap is
      // predictable; the two sibling icon widgets (#IcoItem / #IcoTex) are toggled by hud/IconRenderer.
      Group #MmoscalingInspectAffixRow {
        Anchor: (Height: 30);
        LayoutMode: LeftCenterWrap;

        Group #Affix0 {
          Anchor: (Width: 90, Height: 13);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 12, Height: 12); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 12, Height: 12); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 3); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }

        Group #Affix1 {
          Anchor: (Width: 90, Height: 13);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 12, Height: 12); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 12, Height: 12); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 3); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }

        Group #Affix2 {
          Anchor: (Width: 90, Height: 13);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 12, Height: 12); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 12, Height: 12); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 3); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }

        Group #Affix3 {
          Anchor: (Width: 90, Height: 13);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 12, Height: 12); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 12, Height: 12); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 3); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }
      }
    }
  }
}
