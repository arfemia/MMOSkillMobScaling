// Styled to MATCH the native Hytale objective HUD (client ObjectivePanel + ObjectiveCommon): the
// ObjectivePanelContainer frame plus the bold + LetterSpacing 1 family and the gray/gold palette. The
// frame texture is copied alongside this file so the server-shipped Custom UI can resolve it by name.

@InspectNameStyle = (FontSize: 14, TextColor: #eceff1, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center, Wrap: true);

@InspectRarityStyle = (FontSize: 12, TextColor: #ffffff, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

@InspectLevelStyle = (FontSize: 12, TextColor: #b7b8b9, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

@InspectHpTextStyle = (FontSize: 11, TextColor: #eceff1, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);

@InspectAffixStyle = (FontSize: 13, TextColor: #b7b8b9, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

Group {
  Group #MmoscalingInspectPanel {
    // Static fallback anchor only - the runtime applyConfiguredPosition (MobInspectorHud.defaultPosition)
    // always wins. Left-anchored (NO Horizontal). The native ObjectivePanelContainer frame + padding to
    // clear its ~15px decorative border.
    Anchor: (Top: 216, Left: 16, Width: 320, Height: 126);
    LayoutMode: Left;
    Padding: (Horizontal: 14, Vertical: 10);
    Background: (TexturePath: "ObjectivePanelContainer.png", Border: 15);

    // LEFT column: the target mob's generated portrait (Icons/ModelsGenerated/<role>.png), pushed by Java.
    // Toggled whole via .Visible; when hidden the Left layout collapses it and the info column takes the room.
    AssetImage #MmoscalingInspectPortrait {
      Anchor: (Width: 72, Height: 72);
      Visible: false;
      FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png";
    }

    Group #MmoscalingInspectPortraitGap { Anchor: (Width: 6); }

    // RIGHT column: name / rarity+difficulty / HP bar / affix chips.
    Group #MmoscalingInspectInfo {
      FlexWeight: 1;
      LayoutMode: Top;

      Label #MmoscalingInspectName {
        Text: "";
        Anchor: (Height: 30);
        Style: @InspectNameStyle;
      }

      Group {
        Anchor: (Height: 16);
        LayoutMode: Left;

        // Variant tag (leftmost, matching the "{variant} {rarity} {base}" name order); its TextColor is
        // pushed per-target from Variant.displayColor(). Hidden when the mob has no variant overlay.
        Label #MmoscalingInspectVariant {
          Text: "";
          Anchor: (Height: 16);
          Padding: (Right: 8);
          Style: @InspectRarityStyle;
        }

        Label #MmoscalingInspectRarity {
          Text: "";
          Anchor: (Height: 16);
          Padding: (Right: 8);
          Style: @InspectRarityStyle;
        }

        Label #MmoscalingInspectLevel {
          Text: "";
          Anchor: (Height: 16);
          Style: @InspectLevelStyle;
        }
      }

      // Fixed width so the Java-pushed fill (a fixed 212 = 214 - 2 pad) always fills the BAR exactly,
      // independent of the info column width (which widens when the portrait column is hidden). The bar
      // then stays 214 left-aligned rather than stretching to the column edge.
      Group #MmoscalingInspectHpBg {
        Anchor: (Width: 214, Height: 14);
        Padding: (Full: 1);
        Background: #000000(0.6);

        Group #MmoscalingInspectHpFill {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 0);
          Background: #c94f4f;
        }

        Label #MmoscalingInspectHp {
          Text: "";
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          Style: @InspectHpTextStyle;
        }
      }

      // Affix chips wrap onto a second line. Each chip is a fixed-width icon + name so the wrap is
      // predictable (two 100-wide chips fit the 214 info column); the two sibling icon widgets
      // (#IcoItem / #IcoTex) are toggled by hud/IconRenderer.
      Group #MmoscalingInspectAffixRow {
        Anchor: (Height: 40);
        LayoutMode: LeftCenterWrap;

        Group #Affix0 {
          Anchor: (Width: 100, Height: 18);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 16, Height: 16); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 16, Height: 16); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 4); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }

        Group #Affix1 {
          Anchor: (Width: 100, Height: 18);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 16, Height: 16); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 16, Height: 16); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 4); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }

        Group #Affix2 {
          Anchor: (Width: 100, Height: 18);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 16, Height: 16); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 16, Height: 16); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 4); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }

        Group #Affix3 {
          Anchor: (Width: 100, Height: 18);
          LayoutMode: Left;
          ItemIcon #IcoItem { Visible: false; Anchor: (Width: 16, Height: 16); }
          AssetImage #IcoTex { Visible: false; Anchor: (Width: 16, Height: 16); FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png"; }
          Group #IcoGap { Anchor: (Width: 4); }
          Label #Name { Text: ""; FlexWeight: 1; Style: @InspectAffixStyle; }
        }
      }
    }
  }
}
