// Styled to MATCH the native Hytale objective HUD (client ObjectivePanel + ObjectiveCommon): the
// ObjectivePanelContainer frame, an uppercase-gray heading, gold emphasis values, gray body lines, and
// the bold + LetterSpacing 1 FontSize-15 family. The frame texture is copied alongside this file so the
// server-shipped Custom UI can resolve it by name.

@ZoneTitleStyle = (FontSize: 15, TextColor: #b7b8b9, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

@ZoneTierStyle = (FontSize: 16, TextColor: #e0e0e0, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

@ZoneValueStyle = (FontSize: 13, TextColor: #ca9f37, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

@ZoneLineStyle = (FontSize: 13, TextColor: #b7b8b9, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Start, VerticalAlignment: Center);

Group {
  Group #MmoscalingZonePanel {
    Anchor: (Top: 90, Left: 16, Width: 320, Height: 124);
    LayoutMode: Top;
    Padding: (Horizontal: 16, Top: 12, Bottom: 6);
    Background: (TexturePath: "ObjectivePanelContainer.png", Border: 15);

    Label #MmoscalingZoneTitle {
      Text: "";
      Anchor: (Height: 20);
      Style: @ZoneTitleStyle;
    }

    Label #MmoscalingZoneName {
      Text: "";
      Anchor: (Height: 16);
      Style: @ZoneLineStyle;
    }

    Group {
      Anchor: (Height: 26);
      LayoutMode: Left;

      Label #MmoscalingZoneTier {
        Text: "";
        Anchor: (Height: 26);
        Style: @ZoneTierStyle;
      }

      Label #MmoscalingZoneValue {
        Text: "";
        Anchor: (Height: 26);
        Padding: (Left: 8);
        Style: @ZoneValueStyle;
      }
    }

    Label #MmoscalingZonePower {
      Text: "";
      Anchor: (Height: 16);
      Style: @ZoneLineStyle;
    }

    Label #MmoscalingZoneGroup {
      Text: "";
      Anchor: (Height: 16);
      Style: @ZoneLineStyle;
    }
  }
}
