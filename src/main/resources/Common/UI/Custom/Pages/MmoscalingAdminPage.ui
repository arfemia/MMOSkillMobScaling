$C = "../Common.ui";
$F = "../Common/ZigFrames.ui";
$Z = "../Common/ZigButtons.ui";

// MMO Mob Scaling admin config page (com.ziggfreed.mmomobscaling.pages.MobScalingAdminPage).
// SPEC-DRIVEN: every knob row (Global / Zone HUD / Inspector HUD / Worlds) is appended at runtime by
// the shared ziggfreed-common ui/form engine (Pages/ZigForm*Row.ui) from a Java FieldSpec list - this
// file only lays out the STATIC shell (title, tabs, the four scrolling form containers, the two-panel
// Worlds tab, save/new/clear buttons, the status line) plus the ONE hand-built row that cannot be a
// FieldSpec (the preset dropdown, whose entries are dynamic). Every #Mmoscaling* id is mod-prefixed
// (the client UI namespace is flat + cross-mod). ALL display text is pushed from Java on .TextSpans
// (never .Text) as client-resolved Messages. EVERY labelled button is a RICH ZigRichButton (a Button
// + inner #Label, label set via ZigRichButton.text) - NEVER a TextButton.Text sink. Smoke-test in-game
// (.ui is not gradle-validated).

// ---- local styles / templates ----
@DropStyle = DropdownBoxStyle(
  ...$C.@DefaultDropdownBoxStyle,
  LabelStyle: (...$C.@DefaultDropdownBoxLabelStyle, TextColor: #ffffff, RenderUppercase: false)
);
@HeaderStyle = (FontSize: 15, TextColor: #ffaa4a, RenderBold: true, VerticalAlignment: Center);
@RowLabelStyle = (FontSize: 13, TextColor: #cdd8e6, VerticalAlignment: Center);

// A label + control row (used only by the hand-built preset row now - every other row comes from the
// shared ziggfreed-common ui/form row templates).
@Row = Group {
  LayoutMode: Left;
  Anchor: (Height: 32, Bottom: 5);
};

// The ONE rich button (Button backgrounds + click sounds + a centered inner #Label pushed via
// .TextSpans). Used for tabs and every save / new / clear button - ZigRichButton.text sets the label,
// SettingsUiUtil.setToggle / setTabActive drive the state. @Style overridable per instance.
@RichBtn = Button {
  @Style = $Z.@ZigRichRowBtnStyle;
  Style: @Style;
  Anchor: (Height: 30);
  Label #Label {
    FlexWeight: 1;
    Text: "";
    Style: (FontSize: 13, TextColor: #e6eef7, HorizontalAlignment: Center, VerticalAlignment: Center);
  }
};

// A section header line (used only for the static world-editor header now - every per-knob header
// comes from the shared ZigFormHeaderRow.ui template).
@Header = Label {
  Text: "";
  Anchor: (Height: 24, Top: 6, Bottom: 4);
  Style: @HeaderStyle;
};

$C.@PageOverlay {}

$F.@ZigDecoratedFrame {
  @CloseButton = true;
  Anchor: (Width: 960, Height: 680);

  #Content {
    Label #MmoscalingTitle {
      Text: "";
      Anchor: (Height: 28, Bottom: 6);
      Style: (FontSize: 20, TextColor: #ffd97a, RenderBold: true);
    }

    // Tab bar (rich buttons; active tab tinted from Java via SettingsUiUtil.setTabActive).
    Group #MmoscalingTabBar {
      LayoutMode: Left;
      Anchor: (Height: 32, Bottom: 8);
      @RichBtn #MmoscalingTabGlobal    { FlexWeight: 1; Anchor: (Height: 32); }
      @RichBtn #MmoscalingTabZoneHud   { FlexWeight: 1; Anchor: (Height: 32, Left: 5); }
      @RichBtn #MmoscalingTabInspector { FlexWeight: 1; Anchor: (Height: 32, Left: 5); }
      @RichBtn #MmoscalingTabWorlds    { FlexWeight: 1; Anchor: (Height: 32, Left: 5); }
    }

    // The tab body: exactly one section is Visible at a time.
    Group #MmoscalingBody {
      FlexWeight: 1;
      LayoutMode: Top;

      // ================= GLOBAL (two-panel: settings left, live skeleton preview right) =================
      Group #MmoscalingSectionGlobal {
        FlexWeight: 1;
        LayoutMode: Left;

        // ---- LEFT: static preset row, the scrolling spec-driven form, a static Save button ----
        Group {
          FlexWeight: 1;
          LayoutMode: Top;

          @Row {
            Label #MmoscalingPresetLabel { FlexWeight: 1; Text: ""; Style: @RowLabelStyle; }
            $C.@DropdownBox #MmoscalingPresetDropdown { Anchor: (Width: 200, Height: 30); Style: @DropStyle; }
          }

          Group #MmoscalingGlobalForm {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 4);
          }

          @RichBtn #MmoscalingGlobalSave { @Style = $Z.@ZigRichPrimaryBtnStyle; Anchor: (Height: 32, Top: 6); }
        }

        // Thin vertical separator (matches the Worlds tab's list/editor divider).
        Group { Anchor: (Width: 1, Left: 8, Right: 8); Background: #1e2a36; }

        // ---- RIGHT: live skeleton preview - a plain mob through the difficulty stat curve only ----
        // (rarity/variant multipliers stack on top at spawn; not part of this read). Refreshed from
        // Java on every Global-tab field/press/save/preset event (MobScalingAdminPage.refreshPreview).
        Group {
          Anchor: (Width: 300);
          LayoutMode: Top;
          Padding: (Left: 10);

          Label #MmoscalingPreviewTitle {
            Text: "";
            Anchor: (Height: 22, Bottom: 4);
            Style: (FontSize: 15, TextColor: #ffaa4a, RenderBold: true);
          }
          Label #MmoscalingPreviewNote {
            Text: "";
            Anchor: (Bottom: 8);
            Style: (FontSize: 11, TextColor: #8696a8, Wrap: true);
          }
          Group #MmoscalingPreviewList {
            LayoutMode: Top;
          }

          // Manual difficulty probe (round-3): type any difficulty >= 1 to preview it directly,
          // UNCLAMPED to the live Min/Max cap band (the curve's own multiplier caps still bound the
          // resulting factors) - wired OUTSIDE the spec-driven form, own "previewD" ValueChanged event
          // (MobScalingAdminPage.buildPreviewPanel/handlePreviewDifficulty). Hidden until the field
          // holds a parseable difficulty.
          @Row {
            Anchor: (Height: 30, Top: 6, Bottom: 0);
            Label #MmoscalingPreviewCustomLabel { FlexWeight: 1; Text: ""; Style: @RowLabelStyle; }
            $C.@TextField #MmoscalingPreviewCustomField { Anchor: (Width: 80, Height: 28); Padding: (Horizontal: 8); }
          }
          Label #MmoscalingCustomPreviewLine {
            Text: "";
            Visible: false;
            Anchor: (Top: 4);
            Style: (FontSize: 12, TextColor: #cdd8e6);
          }
        }
      }

      // ================= ZONE HUD =================
      Group #MmoscalingSectionZoneHud {
        Visible: false;
        FlexWeight: 1;
        LayoutMode: Top;

        Group #MmoscalingZoneForm {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 4);
        }

        @RichBtn #MmoscalingZoneSave { @Style = $Z.@ZigRichPrimaryBtnStyle; Anchor: (Height: 32, Top: 6); }
      }

      // ================= INSPECTOR HUD =================
      Group #MmoscalingSectionInspector {
        Visible: false;
        FlexWeight: 1;
        LayoutMode: Top;

        Group #MmoscalingInspectorForm {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 4);
        }

        @RichBtn #MmoscalingInspectorSave { @Style = $Z.@ZigRichPrimaryBtnStyle; Anchor: (Height: 32, Top: 6); }
      }

      // ================= WORLDS (two-panel: list left, add/edit editor right) =================
      Group #MmoscalingSectionWorlds {
        Visible: false;
        FlexWeight: 1;
        LayoutMode: Left;

        // ---- LEFT: the world list ----
        Group {
          Anchor: (Width: 300);
          LayoutMode: Top;

          // Appended per-world rows (Pages/MmoscalingWorldRow.ui, a mod-local wrapping row - not the
          // common ZigListRow): #Title = id (wraps to two lines), #Sub = summary, #Badge =
          // shipped/override, rich #EditBtn / #RemoveBtn.
          Group #MmoscalingWorldList {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 4);
          }
          Label #MmoscalingWorldEmpty {
            Text: "";
            Visible: false;
            Anchor: (Height: 20, Top: 4, Bottom: 4);
            Style: (FontSize: 12, TextColor: #8696a8, HorizontalAlignment: Center);
          }
          @RichBtn #MmoscalingWorldNew { Anchor: (Height: 32, Top: 6); }
        }

        // Thin vertical separator between the list and the editor.
        Group { Anchor: (Width: 1, Left: 8, Right: 8); Background: #1e2a36; }

        // ---- RIGHT: add / edit editor ----
        // Blank fields / the Inherit dropdown option inherit the Parent chain then the global fold.
        // Pool allow/deny lists are comma-separated ids (deny wins); everything is editable here now.
        Group {
          FlexWeight: 1;
          LayoutMode: Top;

          @Header #MmoscalingWorldEditorHeader {}

          Group #MmoscalingWorldForm {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 4);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 32, Top: 6);
            @RichBtn #MmoscalingWorldSave  { @Style = $Z.@ZigRichPrimaryBtnStyle; FlexWeight: 1; Anchor: (Height: 32); }
            @RichBtn #MmoscalingWorldClear { FlexWeight: 1; Anchor: (Height: 32, Left: 6); }
          }
        }
      }
    }

    Label #MmoscalingStatus {
      Text: "";
      Visible: false;
      Anchor: (Height: 20, Top: 6);
      Style: (FontSize: 12, TextColor: #4aff7f, HorizontalAlignment: Center);
    }
  }
}
