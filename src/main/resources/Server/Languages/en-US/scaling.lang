# MMO Mob Scaling - en-US (authoritative). The engine derives the "scaling." namespace from THIS
# file's name (scaling.lang), so keys here are UNPREFIXED (rarity.rare.name -> scaling.rarity.rare.name).
# Rarity/affix display names + qualitative affix descriptions. Affix .desc is QUALITATIVE ONLY - NO digits
# (magnitudes live in the EntityEffect assets and would drift if restated here). No em-dashes.

rarity.rare.name = Rare
rarity.epic.name = Epic
rarity.legendary.name = Legendary
rarity.boss.name = Boss
variant.horrific.name = Horrific

# Decorated display-name FRAME (death messages / kill feed / logs, NOT the overhead nameplate).
# Both params are NESTED client-resolved messages; translators reorder the frame per locale.
name.decorated = {rarity} {base}
name.variant_decorated = {variant} {inner}

# /mobscaling admin command (descriptions resolve as lang keys; hytale:Admin only).
command.desc = Mob-scaling admin tools: purge residue, inspect local difficulty, tune the HUD overlays.
command.arg.sub = Subcommand: purge strips scaling residue off loaded mobs; inspect reports the difficulty inputs here; hud tunes the overlays; preset switches the active preset; intensity tunes the difficulty multiplier; worlds lists the per-world settings files; ui opens the admin config page.
command.usage = Usage: /mobscaling <purge|inspect|hud|preset|intensity|worlds|ui>
command.arg.intensity = The intensity multiplier (>= 0; 1.0 neutral, higher = tougher mobs). Omit to show the current value.
command.players_only = This command must be run by a player.
command.purge.start = Sweeping scaling residue off loaded mobs in this world...
command.purge.done = Purged scaling residue from {count} loaded mobs.
command.inspect.header = Mob scaling at your position:
command.inspect.power = Your power level: {power}
command.inspect.world = World difficulty floor: {floor} (scaling active: {enabled})
command.inspect.zone = Zone {zone}: base floor {base}, distance bonus +{bonus}, effective floor {floor}
command.inspect.region = Tracked region power: {power} (mode {mode}, tracked players: {tracked})
command.inspect.difficulty = Effective spawn difficulty here: {difficulty}
command.inspect.curve = Plain-mob stat curve here: HP x{hp}, outgoing dmg x{out}, incoming taken x{in}
command.inspect.chance = Rarity spawn chance: {chance}

# /mobscaling preset - switch the active settings preset live (Default, Casual, Hardcore, Playtest).
command.preset.usage = Usage: /mobscaling preset [name]
command.preset.active = Active preset: {0}
command.preset.available = Available presets: {0}
command.preset.swapped = Switched to preset {0}.
command.preset.unknown = Unknown preset {0}. Available: {1}
command.preset.saved = Saved: the active preset now persists across restarts.

# /mobscaling worlds - list the folded per-world settings files (Worlds/*.json across jar + packs + the owner dir).
command.worlds.empty = No per-world settings files are loaded.
command.worlds.header = Per-world settings ({count} files):
command.worlds.entry = {id}: match {match}, parent {parent}, {origin}, scaling enabled: {enabled}
command.worlds.base = (base only, never matched)
command.worlds.origin_owner = owner file
command.worlds.origin_shipped = shipped

# /mobscaling intensity - live-tune the GLOBAL difficulty-to-stat multiplier (runtime only; the owner file is the persistent authority).
command.intensity.current = Current intensity multiplier: {value}
command.intensity.set = Intensity multiplier set to {value}.
command.intensity.usage = Usage: /mobscaling intensity [multiplier]. A number >= 0 (1.0 = neutral, higher = tougher mobs).
command.intensity.persist_hint = Live change only: to keep it across restarts, set the Intensity key in mods/MmoMobScaling/mob-scaling.json.
command.intensity.saved = Saved: the intensity multiplier now persists across restarts.

# /mobscaling hud - live overlay tuning (runtime only; the owner file is the persistent authority).
command.hud.usage = Usage: /mobscaling hud <zone|inspector> <on|off|POSITION> [offsetX] [offsetY]. Positions: TOP_LEFT, TOP_CENTER, TOP_RIGHT, CENTER_LEFT, CENTER, CENTER_RIGHT, BOTTOM_LEFT, BOTTOM_CENTER, BOTTOM_RIGHT.
command.hud.enabled = HUD enabled for all players: {target}
command.hud.disabled = HUD disabled for all players: {target}
command.hud.moved = Repositioned {target} to {position} (offset {x}, {y}).
command.hud.persist_hint = Live change only: to keep it across restarts, set the ZoneHud/InspectorHud keys in mods/MmoMobScaling/mob-scaling.json.
command.hud.saved = Saved: the HUD change now persists across restarts.
command.hud.target.zone = zone difficulty HUD
command.hud.target.inspector = mob inspector HUD
command.arg.hud_target = Which HUD: zone or inspector.
command.arg.hud_value = on, off, or a position preset such as TOP_LEFT.
command.arg.hud_offset_x = Optional pixel offset from the anchored horizontal edge.
command.arg.hud_offset_y = Optional pixel offset from the anchored vertical edge.

# Zone-difficulty HUD (the tier words are qualitative threat reads relative to the viewer).
hud.zone.title = ZONE DIFFICULTY
# Location line: {0} = zone name, {1} = biome name. A pure separator template (translators reorder /
# reglyph the separator per locale); no English words so it reads cleanly in every locale.
hud.zone.location = {0} - {1}
hud.zone.difficulty = Difficulty {value}
hud.zone.power = Your power: {power}
hud.zone.group = Group power: {power}
hud.zone.tier.trivial = Trivial
hud.zone.tier.easy = Easy
hud.zone.tier.fair = Fair
hud.zone.tier.hard = Hard
hud.zone.tier.deadly = Deadly

# Mob-inspector HUD (name + rarity render from their own keys; these are the fixed frames).
hud.inspect.difficulty = Difficulty {value}
hud.inspect.hp = {current} / {max}

affix.armored.name = Armored
affix.armored.desc = Clad in heavy plating that turns aside blows.
affix.stalwart.name = Stalwart
affix.stalwart.desc = Rooted like old stone; nothing knocks it back.
affix.swift.name = Swift
affix.swift.desc = Moves with unnatural quickness.
affix.vampiric.name = Vampiric
affix.vampiric.desc = Drains life from its foes with every strike.
affix.freezing.name = Freezing
affix.freezing.desc = Its chilling touch numbs and slows the unwary.
affix.venomous.name = Venomous
affix.venomous.desc = Its bite courses with burning venom.

