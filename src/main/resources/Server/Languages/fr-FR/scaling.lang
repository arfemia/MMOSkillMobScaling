name.decorated = {base} {rarity}
name.variant_decorated = {variant} {inner}

command.desc = Outils d'administration de la mise à l'échelle des créatures : purger les résidus, inspecter la difficulté locale, régler les superpositions HUD.
command.arg.sub = Sous-commande : purge retire les résidus de mise à l'échelle des créatures chargées ; inspect affiche les valeurs de difficulté à votre position ; hud règle les superpositions ; preset bascule vers le préréglage actif ; intensity règle le multiplicateur de difficulté ; ui ouvre la page de configuration d'administration.
command.usage = Utilisation : /mobscaling <purge|inspect|hud|preset|intensity|ui>
command.players_only = Cette commande doit être exécutée par un joueur.
command.purge.start = Suppression des résidus de mise à l'échelle des créatures chargées dans ce monde...
command.purge.done = Résidus de mise à l'échelle retirés de {count} créatures chargées.
command.inspect.header = Mise à l'échelle des créatures à votre position :
command.inspect.power = Votre niveau de puissance : {power}
command.inspect.world = Plancher de difficulté du monde : {floor} (mise à l'échelle active : {enabled})
command.inspect.zone = Zone {zone} : plancher de base {base}, bonus de distance +{bonus}, plancher effectif {floor}
command.inspect.region = Puissance suivie de la région : {power} (mode {mode}, joueurs suivis : {tracked})
command.inspect.difficulty = Difficulté d'apparition effective ici : {difficulty}
command.inspect.curve = Courbe de statistiques des créatures ordinaires ici : HP x{hp}, dégâts infligés x{out}, dégâts subis x{in}
command.inspect.chance = Chance de rareté à l'apparition : {chance}

command.hud.usage = Utilisation : /mobscaling hud <zone|inspector> <on|off|POSITION> [offsetX] [offsetY]. Positions : TOP_LEFT, TOP_CENTER, TOP_RIGHT, CENTER_LEFT, CENTER, CENTER_RIGHT, BOTTOM_LEFT, BOTTOM_CENTER, BOTTOM_RIGHT.
command.hud.enabled = HUD activé pour tous les joueurs : {target}
command.hud.disabled = HUD désactivé pour tous les joueurs : {target}
command.hud.moved = {target} repositionné en {position} (décalage {x}, {y}).
command.hud.persist_hint = Changement en direct uniquement : pour le conserver après un redémarrage, définissez les clés ZoneHud/InspectorHud dans mods/MmoMobScaling/mob-scaling.json.
command.hud.saved = Enregistré : la modification HUD persiste maintenant après les redémarrages.
command.hud.target.zone = HUD de difficulté de zone
command.hud.target.inspector = HUD de l'inspecteur de créatures
command.arg.hud_target = Quel HUD : zone ou inspector.
command.arg.hud_value = on, off, ou un préréglage de position tel que TOP_LEFT.
command.arg.hud_offset_x = Décalage optionnel en pixels depuis le bord horizontal ancré.
command.arg.hud_offset_y = Décalage optionnel en pixels depuis le bord vertical ancré.
command.arg.intensity = Le multiplicateur d'intensité (>= 0 ; 1.0 neutre, plus élevé = créatures plus coriaces). Omettez-le pour afficher la valeur actuelle.
command.preset.usage = Utilisation : /mobscaling preset [nom]
command.preset.active = Préréglage actif : {0}
command.preset.available = Préréglages disponibles : {0}
command.preset.swapped = Basculé vers le préréglage {0}.
command.preset.unknown = Préréglage {0} inconnu. Disponibles : {1}
command.preset.saved = Enregistré : le préréglage actif persiste maintenant après les redémarrages.

command.intensity.current = Multiplicateur d'intensité actuel : {value}
command.intensity.set = Multiplicateur d'intensité défini à {value}.
command.intensity.usage = Utilisation : /mobscaling intensity [multiplicateur]. Un nombre >= 0 (1.0 = neutre, plus élevé = créatures plus coriaces).
command.intensity.persist_hint = Changement en direct uniquement : pour le conserver après un redémarrage, définissez la clé Intensity dans mods/MmoMobScaling/mob-scaling.json.
command.intensity.saved = Enregistré : le multiplicateur d'intensité persiste maintenant après les redémarrages.

