hud.zone.power = Votre puissance : {power}
hud.zone.group = Puissance du groupe : {power}
hud.zone.tier.trivial = Insignifiant
hud.zone.tier.easy = Facile
hud.zone.tier.fair = Équilibré
hud.zone.tier.hard = Difficile
hud.zone.tier.deadly = Mortel

hud.zone.location = {0} - {1}
