hud.zone.group = Poder do grupo: {power}
hud.zone.tier.trivial = Trivial
hud.zone.tier.easy = Fácil
hud.zone.tier.fair = Equilibrado
hud.zone.tier.hard = Difícil
hud.zone.tier.deadly = Mortal

