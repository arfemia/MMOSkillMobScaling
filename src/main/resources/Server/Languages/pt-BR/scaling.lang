# MMO Mob Scaling - pt-BR. Keys are UNPREFIXED (the filename is the namespace). No em-dashes.
# Affix .desc is QUALITATIVE ONLY - no digits (magnitudes live in the EntityEffect assets).

rarity.rare.name = Raro
rarity.epic.name = Épico
rarity.legendary.name = Lendário
rarity.boss.name = Chefe
variant.horrific.name = Horrível

