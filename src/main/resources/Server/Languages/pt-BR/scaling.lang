command.desc = Ferramentas de administração do escalonamento de criaturas: limpar resíduos, inspecionar a dificuldade local, ajustar as sobreposições de HUD.
command.arg.sub = Subcomando: purge remove os resíduos de escalonamento das criaturas carregadas; inspect mostra os valores de dificuldade na sua posição; hud ajusta as sobreposições; preset alterna a predefinição ativa; intensity ajusta o multiplicador de dificuldade; worlds lista os arquivos de configuração por mundo; ui abre a página de configuração do administrador.
command.usage = Uso: /mobscaling <purge|inspect|hud|preset|intensity|worlds|ui>
command.players_only = Este comando só pode ser executado por um jogador.
command.purge.start = Removendo resíduos de escalonamento das criaturas carregadas neste mundo...
command.purge.done = Resíduos de escalonamento removidos de {count} criaturas carregadas.
command.inspect.header = Escalonamento de criaturas na sua posição:
command.inspect.power = Seu nível de poder: {power}
command.inspect.world = Piso de dificuldade do mundo: {floor} (escalonamento ativo: {enabled})
command.inspect.zone = Zona {zone}: piso base {base}, bônus de distância +{bonus}, piso efetivo {floor}
command.inspect.region = Poder registrado da região: {power} (modo {mode}, jogadores registrados: {tracked})
command.inspect.difficulty = Dificuldade efetiva de surgimento aqui: {difficulty}
command.inspect.curve = Curva de atributos de criatura comum aqui: HP x{hp}, dano causado x{out}, dano recebido x{in}
command.inspect.chance = Chance de raridade ao surgir: {chance}

command.preset.usage = Uso: /mobscaling preset [nome]
command.preset.active = Predefinição ativa: {0}
command.preset.available = Predefinições disponíveis: {0}
command.preset.swapped = Alterado para a predefinição {0}.
command.preset.unknown = Predefinição desconhecida {0}. Disponíveis: {1}
command.preset.saved = Salvo: a predefinição ativa agora persiste entre reinicializações.

command.worlds.empty = Nenhum arquivo de configuração por mundo está carregado.
command.worlds.header = Configurações por mundo ({count} arquivos):
command.worlds.entry = {id}: correspondência {match}, pai {parent}, {origin}, escalonamento ativado: {enabled}
command.worlds.base = (somente base, nunca correspondido)
command.worlds.origin_owner = arquivo do proprietário
command.worlds.origin_shipped = padrão

command.intensity.current = Multiplicador de intensidade atual: {value}
command.intensity.set = Multiplicador de intensidade definido como {value}.
command.intensity.usage = Uso: /mobscaling intensity [multiplicador]. Um número >= 0 (1,0 = neutro, maior = criaturas mais difíceis).
command.intensity.persist_hint = Alteração apenas em tempo real: para mantê-la após reinicializações, defina a chave Intensity em mods/MmoMobScaling/mob-scaling.json.
command.intensity.saved = Salvo: o multiplicador de intensidade agora persiste entre reinicializações.

command.hud.usage = Uso: /mobscaling hud <zone|inspector> <on|off|POSITION> [offsetX] [offsetY]. Posições: TOP_LEFT, TOP_CENTER, TOP_RIGHT, CENTER_LEFT, CENTER, CENTER_RIGHT, BOTTOM_LEFT, BOTTOM_CENTER, BOTTOM_RIGHT.
command.hud.enabled = HUD ativado para todos os jogadores: {target}
command.hud.disabled = HUD desativado para todos os jogadores: {target}
command.hud.moved = {target} reposicionado para {position} (deslocamento {x}, {y}).
command.hud.persist_hint = Alteração apenas em tempo real: para mantê-la após reinicializações, defina as chaves ZoneHud/InspectorHud em mods/MmoMobScaling/mob-scaling.json.
command.hud.saved = Salvo: a alteração de HUD agora persiste entre reinicializações.
command.hud.target.zone = HUD de dificuldade de zona
command.hud.target.inspector = HUD de inspeção de criaturas
command.arg.hud_target = Qual HUD: zone ou inspector.
command.arg.hud_value = on, off, ou uma predefinição de posição como TOP_LEFT.
command.arg.hud_offset_x = Deslocamento opcional em pixels a partir da borda horizontal ancorada.
command.arg.hud_offset_y = Deslocamento opcional em pixels a partir da borda vertical ancorada.
command.arg.intensity = O multiplicador de intensidade (>= 0; 1,0 neutro, maior = criaturas mais difíceis). Omita para mostrar o valor atual.

