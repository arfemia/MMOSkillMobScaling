# ============================================================================
# Sugerencias de configuración en línea (endurecimiento UX del administrador round-2). UNA oración cualitativa cada una, sin dígitos
# (las magnitudes viven en los valores mismos / se desviarían si se reiteraran aquí). Un campo de formulario de mundo que refleja
# un concepto global IDÉNTICO reutiliza la clave de sugerencia correspondiente a continuación (ver MobScalingAdminPage.buildWorldSpecs);
# un campo de tri-estado, una puerta de grupo o un campo de identidad mundial no tiene un equivalente global verdadero y obtiene su propia clave.
# ============================================================================

# Pestaña Global.
ui.hint.enabled = Interruptor maestro del sistema de escalado de criaturas. Desactivarlo elimina todos los efectos de escalado al reiniciar.
ui.hint.floor = La dificultad más baja a la que cae un mundo antes de que se apliquen bonificaciones de zona, bioma o distancia.
ui.hint.min_cap = La dificultad efectiva más baja a la que una criatura puede resolverse, después de agregar todos los bonificadores.
ui.hint.max_cap = La dificultad efectiva más alta a la que una criatura puede resolverse, después de agregar todos los bonificadores.
ui.hint.intensity = Escala qué tan empinada crece la curva de dificultad; más alto hace que las criaturas escaladas sean más duras y golpeen más fuerte.
ui.hint.hp_per_point = Cuánto aumenta la resistencia de salud de una criatura por cada punto de dificultad por encima de la línea base.
ui.hint.out_per_point = Cuánto más fuerte golpea una criatura por cada punto de dificultad por encima de la línea base.
ui.hint.in_reduction = Cuánto daño entrante se evita por cada punto de dificultad por encima de la línea base.
ui.hint.max_hp = El techo más duro al que la curva de dificultad puede empujar el multiplicador de salud de una criatura.
ui.hint.max_out = El techo más duro al que la curva de dificultad puede empujar el multiplicador de daño infligido de una criatura.
ui.hint.min_in = La reducción de daño entrante máxima que la curva de dificultad puede conceder a una criatura.
ui.hint.rarity = La probabilidad de que una criatura hostil aparezca con un nivel raro o superior en lugar de simple.
ui.hint.esc_enabled = Si la dificultad aumenta cuanto más lejos se aleja un jugador del punto de aparición del mundo.
ui.hint.esc_start = La distancia desde la aparición que un jugador puede viajar antes de que la escalación de distancia comience a añadir dificultad.
ui.hint.esc_blocks = Cuántos bloques después de la distancia de inicio agregan un punto más de dificultad.
ui.hint.esc_max_bonus = La dificultad extra máxima que la escalación de distancia puede añadir.
ui.hint.esc_rarity = Cuánta probabilidad de rareza adicional agrega la escalación de distancia por punto de escalación.
ui.hint.player_scaling = Si los jugadores cercanos y su poder aumentan la dificultad de una región.
ui.hint.aggregation = Cómo el poder de múltiples jugadores cercanos se pliega en una lectura de dificultad de región.
ui.hint.region_size = El tamaño de la cuadrícula de proximidad utilizada para agrupar jugadores en una lectura de región compartida.
ui.hint.band_width = Lo máximo que la dificultad de una región puede variar por encima de su línea base por el poder de jugadores cercanos.
ui.hint.only_raise = Cuando está activado, el poder de los jugadores cercanos solo puede aumentar la dificultad de una región, nunca reducirla por debajo de la línea base.
ui.hint.party_join = Si un jugador más fuerte o un grupo que se une a una región aumenta su dificultad inmediatamente.
ui.hint.late_arrival = El tamaño del aumento de dificultad único aplicado cuando una llegada más fuerte se une a una región.
ui.hint.composition = Si la composición de jugadores cercanos, no solo su poder bruto, influye en el escalado.

# Pestaña HUD de Zona (hud_position/hud_offset_x/hud_offset_y se comparten con la pestaña HUD del Inspector a continuación).
ui.hint.zone_enabled = Si la superposición de dificultad de zona se muestra en pantalla.
ui.hint.zone_show_location = Si la superposición también muestra el nombre de la zona y bioma actual.
ui.hint.hud_position = En qué esquina de la pantalla se ancla la superposición.
ui.hint.hud_offset_x = Ajuste fino en píxeles desde el borde horizontal anclado.
ui.hint.hud_offset_y = Ajuste fino en píxeles desde el borde vertical anclado.
ui.hint.zone_name_prefix = El prefijo de clave de idioma utilizado para buscar un nombre amistoso de la zona actual.
ui.hint.biome_name_prefix = El prefijo de clave de idioma utilizado para buscar un nombre amistoso del bioma actual.

# Pestaña HUD del Inspector.
ui.hint.insp_enabled = Si la superposición del inspector de criaturas de mira se muestra en pantalla.
ui.hint.insp_portrait = Si la tarjeta del inspector muestra la imagen de retrato generada del objetivo.
ui.hint.insp_range = Cuán lejos llega la mira para detectar una criatura a inspeccionar.

# Pestaña Mundos: campos de identidad mundial, tri-estados y puertas de grupo (sin equivalente global para reutilizar).
ui.hint.world_id = El nombre de archivo bajo el que se guardan los ajustes de este mundo; dejar en blanco para derivarlo del patrón de coincidencia.
ui.hint.world_match = A qué mundo se aplica este archivo: un nombre exacto, un prefijo de comodín, o un comodín simple para cada mundo.
ui.hint.world_parent = Otro archivo de mundo del que heredar ajustes antes de que se apliquen las anulaciones propias de este archivo.
ui.hint.w_enabled = Si el escalado de criaturas se ejecuta en este mundo en absoluto. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.w_esc_enabled = Si la escalación de distancia se aplica en este mundo. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.w_player_scaling = Si los jugadores cercanos aumentan la dificultad en este mundo. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.w_only_raise = Si el poder de los jugadores cercanos solo puede aumentar, nunca reducir, la dificultad aquí. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.w_party_join = Si una llegada más fuerte aumenta la dificultad aquí inmediatamente. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.w_composition = Si la composición del jugador influye en el escalado aquí. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.pool_rarities_allow = Niveles de rareza permitidos para tirar aquí; dejar en blanco para permitir todos los niveles.
ui.hint.pool_rarities_deny = Niveles de rareza prohibidos para tirar aquí; la denegación siempre prevalece sobre la permitida.
ui.hint.pool_variants_allow = Superposiciones variantes permitidas para tirar aquí; dejar en blanco para permitir cada variante.
ui.hint.pool_variants_deny = Superposiciones variantes prohibidas para tirar aquí; la denegación siempre prevalece sobre la permitida.
ui.hint.pool_variant_chance = Escala la frecuencia con la que una superposición variante elegible aparece en este mundo.
ui.hint.pool_affixes_allow = Affixes permitidos para tirar aquí; dejar en blanco para permitir cada affix.
ui.hint.pool_affixes_deny = Affixes prohibidos para tirar aquí; la denegación siempre prevalece sobre la permitida.
ui.hint.pool_extra_slots = Espacios de affix adicionales otorgados además de lo que la rareza y variante ya permiten.
ui.hint.w_zone_hud = Si se permite que la superposición de dificultad de zona se muestre en este mundo. Heredar sigue el archivo padre, luego el ajuste global.
ui.hint.w_inspector_hud = Si se permite que la superposición del inspector de criaturas se muestre en este mundo. Heredar sigue el archivo padre, luego el ajuste global.
