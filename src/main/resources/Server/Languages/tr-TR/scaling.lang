# ============================================================================
# Inline setting hints (round-2 admin-UX hardening). ONE qualitative sentence each, no digits (magnitudes
# live in the values themselves / would drift if restated here). A world-form field that mirrors an
# IDENTICAL global concept reuses the matching hint key below; a tri-state, a pool gate, or a
# world-identity field has no true global equivalent and gets its own key.
# ============================================================================

# Global tab.
ui.hint.enabled = Yaratık-ölçekleme sistemleri için ana şalter. Bunu kapatmak yeniden başlatmada tüm ölçekleme etkilerini kaldırır.
ui.hint.floor = Bir dünyanın bölge, biome veya mesafe bonuları uygulanmadan önce düştüğü en düşük zorluk.
ui.hint.min_cap = Bir yaratığın tüm bonuslar eklendikten sonra ulaşabileceği en düşük etkin zorluk.
ui.hint.max_cap = Bir yaratığın tüm bonuslar eklendikten sonra ulaşabileceği en yüksek etkin zorluk.
ui.hint.intensity = Zorluk eğrisinin ne kadar dik yükseldiğini ölçekler; daha yüksek değerler ölçeklenen yaratıkları daha sert ve daha güçlü hale getirir.
ui.hint.hp_per_point = Bir yaratığın sağlığının taban seviyesinin üzerindeki her zorluk noktası için ne kadar arttığı.
ui.hint.out_per_point = Bir yaratığın taban seviyesinin üzerindeki her zorluk noktası için ne kadar daha güçlü vurduğu.
ui.hint.in_reduction = Bir yaratığın taban seviyesinin üzerindeki her zorluk noktası için ne kadar gelen hasarı azalttığı.
ui.hint.max_hp = Zorluk eğrisinin bir yaratığın sağlık çarpanını itebileceği en yüksek sınır.
ui.hint.max_out = Zorluk eğrisinin bir yaratığın giden hasar çarpanını itebileceği en yüksek sınır.
ui.hint.min_in = Zorluk eğrisinin bir yaratığa verebileceği en yüksek gelen hasar azaltması.
ui.hint.rarity = Düşmanca bir yaratığın sıradan yerine nadir veya daha yüksek seviye ile belirme şansı.
ui.hint.esc_enabled = Zorluk seviyesinin oyuncunun dünya doğum noktasından ne kadar uzaklaştığına bağlı olarak yükselip yükselmediği.
ui.hint.esc_start = Oyuncunun mesafe kademeli artışı zorluğu eklemeye başlamadan önce spawn noktasından gidebileceği mesafe.
ui.hint.esc_blocks = Başlangıç mesafesinin kaç blok ötesine geçmenin bir zorluk noktası eklediği.
ui.hint.esc_max_bonus = Mesafe kademeli artışının ekleyebileceği en yüksek ek zorluk.
ui.hint.esc_rarity = Mesafe kademeli artışının her bir kademeli artış noktası başına ne kadar ek nadirlik belirme şansı eklediği.
ui.hint.player_scaling = Yakındaki oyuncuların ve güçlerinin bir bölgenin zorluğunu hiç yükseltip yükseltmediği.
ui.hint.aggregation = Yakındaki birden fazla oyuncunun gücünün bir bölge zorluk değerine nasıl birleştirildiği.
ui.hint.region_size = Oyuncuları paylaşılan bir bölge okumasına göre gruplaştırmak için kullanılan yakınlık ızgarasının boyutu.
ui.hint.band_width = Bir bölgenin zorluğunun yakındaki oyuncu gücü nedeniyle taban seviyesinin üzerine ne kadar sallanabildığinin en yüksek miktarı.
ui.hint.only_raise = Açık olduğunda, yakındaki oyuncu gücü bir bölgenin zorluğunu yalnızca yükseltebilir, hiçbir zaman taban seviyesinin altına düşüremez.
ui.hint.party_join = Daha güçlü bir oyuncunun veya partinin bir bölgeye katılmasının hemen zorluğu yükseltip yükseltmediği.
ui.hint.late_arrival = Daha güçlü bir katılımcı bir bölgeye katıldığında uygulanan bir kerelik zorluk yükselişinin boyutu.
ui.hint.composition = Yakındaki oyuncuların sadece ham gücü değil, bileşiminin ölçeklemede rol oynadığı.

