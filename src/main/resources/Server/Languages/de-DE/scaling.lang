rarity.epic.name = Episch
rarity.legendary.name = Legendär
rarity.boss.name = Boss
variant.horrific.name = Grauenhaft

affix.armored.name = Gepanzert
affix.armored.desc = In schwere Panzerplatten gehüllt, die Schläge abgleiten lassen.
affix.stalwart.name = Standhaft
affix.stalwart.desc = Verwurzelt wie alter Fels; nichts wirft es zurück.
