name.decorated = {rarity} {base}
name.variant_decorated = {variant} {inner}

command.desc = Admin-Werkzeuge für die Mob-Skalierung: Rückstände bereinigen, lokale Schwierigkeit prüfen, HUD-Anzeigen einstellen.
command.arg.sub = Unterbefehl: purge entfernt Skalierungsrückstände von geladenen Mobs; inspect meldet die Schwierigkeitswerte hier; hud passt die Anzeigen an; preset wechselt die aktive Voreinstellung; intensity passt den Schwierigkeitsmultiplikator an; ui öffnet die Admin-Konfigurationsseite.
command.usage = Verwendung: /mobscaling <purge|inspect|hud|preset|intensity|ui>
command.players_only = Dieser Befehl kann nur von einem Spieler ausgeführt werden.
command.purge.start = Entferne Skalierungsrückstände von geladenen Mobs in dieser Welt...
command.purge.done = Skalierungsrückstände von {count} geladenen Mobs entfernt.
command.inspect.header = Mob-Skalierung an deiner Position:
command.inspect.power = Deine Machtstufe: {power}
command.inspect.world = Schwierigkeitsuntergrenze der Welt: {floor} (Skalierung aktiv: {enabled})
command.inspect.zone = Zone {zone}: Basisuntergrenze {base}, Distanzbonus +{bonus}, effektive Untergrenze {floor}
command.inspect.region = Erfasste Regionsmacht: {power} (Modus {mode}, erfasste Spieler: {tracked})
command.inspect.difficulty = Effektive Spawn-Schwierigkeit hier: {difficulty}
command.inspect.chance = Seltenheits-Spawnchance: {chance}
command.inspect.curve = Statuskurve für einfache Mobs hier: HP x{hp}, ausgehender Schaden x{out}, erlittener Schaden x{in}

command.preset.usage = Verwendung: /mobscaling preset [name]
command.preset.active = Aktives Preset: {0}
command.preset.available = Verfügbare Presets: {0}
command.preset.swapped = Zu Preset {0} gewechselt.
command.preset.unknown = Unbekanntes Preset {0}. Verfügbar: {1}
command.preset.saved = Gespeichert: Das aktive Preset wird nun über Neustarts hinweg gespeichert.

# /mobscaling intensity - Schwierigkeitsmultiplikator live einstellen (nur zur Laufzeit; die Datei ist die persistent Autorität).
command.intensity.current = Aktueller Schwierigkeitsmultiplikator: {value}
command.intensity.set = Schwierigkeitsmultiplikator auf {value} gesetzt.
command.intensity.usage = Verwendung: /mobscaling intensity [multiplier]. Eine Zahl >= 0 (1.0 = neutral, höher = schwierigere Mobs).
command.intensity.persist_hint = Nur zur Laufzeit: um die Änderung über Neustarts zu behalten, setze den Intensity-Schlüssel in mods/MmoMobScaling/mob-scaling.json.
command.intensity.saved = Gespeichert: Der Schwierigkeitsmultiplikator wird nun über Neustarts hinweg gespeichert.

command.hud.usage = Verwendung: /mobscaling hud <zone|inspector> <on|off|POSITION> [offsetX] [offsetY]. Positionen: TOP_LEFT, TOP_CENTER, TOP_RIGHT, CENTER_LEFT, CENTER, CENTER_RIGHT, BOTTOM_LEFT, BOTTOM_CENTER, BOTTOM_RIGHT.
command.hud.enabled = HUD für alle Spieler aktiviert: {target}
command.hud.disabled = HUD für alle Spieler deaktiviert: {target}
command.hud.moved = {target} nach {position} verschoben (Versatz {x}, {y}).
command.hud.persist_hint = Nur zur Laufzeit: um die Änderung über Neustarts zu behalten, setze die ZoneHud/InspectorHud-Schlüssel in mods/MmoMobScaling/mob-scaling.json.
command.hud.saved = Gespeichert: Die HUD-Änderung wird nun über Neustarts hinweg gespeichert.
command.hud.target.zone = Zonen-Schwierigkeits-HUD
command.hud.target.inspector = Mob-Inspektor-HUD
command.arg.hud_target = Welches HUD: zone oder inspector.
command.arg.hud_value = on, off oder eine Positionsvorgabe wie TOP_LEFT.
command.arg.hud_offset_x = Optionaler Pixelversatz von der verankerten horizontalen Kante.
command.arg.hud_offset_y = Optionaler Pixelversatz von der verankerten vertikalen Kante.
command.arg.intensity = Der Schwierigkeitsmultiplikator (>= 0; 1.0 neutral, höher = schwierigere Mobs). Weglassen, um den aktuellen Wert anzuzeigen.

