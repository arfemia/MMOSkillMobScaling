# MMO Mob Scaling - it-IT. Keys are UNPREFIXED (the filename is the namespace). No em-dashes.
# Affix .desc is QUALITATIVE ONLY - no digits (magnitudes live in the EntityEffect assets).

rarity.rare.name = Raro
rarity.epic.name = Epico
rarity.legendary.name = Leggendario
rarity.boss.name = Boss
variant.horrific.name = Orribile

affix.armored.name = Corazzato
affix.armored.desc = Coperto di pesanti piastre che deviano i colpi.
affix.stalwart.name = Incrollabile
affix.stalwart.desc = Radicato come pietra antica; nulla lo respinge.
affix.swift.name = Rapido
affix.swift.desc = Si muove con rapidità innaturale.
affix.vampiric.name = Vampirico
affix.vampiric.desc = Drena la vita dei nemici a ogni colpo.
affix.freezing.name = Gelido
affix.freezing.desc = Il suo tocco gelido intorpidisce e rallenta gli incauti.
affix.venomous.name = Velenoso
affix.venomous.desc = Il suo morso arde di veleno bruciante.

name.decorated = {base} {rarity}
name.variant_decorated = {variant} {inner}

command.desc = Strumenti di amministrazione del ridimensionamento delle creature: rimuovere i residui, ispezionare la difficoltà locale, regolare le sovrimpressioni HUD.
command.arg.sub = Sottocomando: purge rimuove i residui di ridimensionamento dalle creature caricate; inspect mostra i valori di difficoltà nella tua posizione; hud regola le sovrimpressioni; preset attiva il preset selezionato; intensity regola il moltiplicatore di difficoltà; worlds elenca i file di impostazioni per mondo; ui apre la pagina di configurazione amministratore.
command.usage = Uso: /mobscaling <purge|inspect|hud|preset|intensity|worlds|ui>
command.players_only = Questo comando può essere eseguito solo da un giocatore.
command.preset.usage = Uso: /mobscaling preset [nome]
command.preset.active = Preset attivo: {0}
command.preset.available = Preset disponibili: {0}
command.preset.swapped = Passato al preset {0}.
command.preset.unknown = Preset sconosciuto {0}. Disponibili: {1}
command.preset.saved = Salvato: il preset attivo persiste ora tra i riavvii.

# /mobscaling worlds - elenca i file di impostazioni per mondo uniti (Worlds/*.json tra jar, pacchetti e file del proprietario).
command.worlds.empty = Nessun file di impostazioni per mondo caricato.
command.worlds.header = Impostazioni per mondo ({count} file):
command.worlds.entry = {id}: corrispondenza {match}, principale {parent}, {origin}, ridimensionamento attivo: {enabled}
command.worlds.base = (solo base, mai corrispondente)
command.worlds.origin_owner = file del proprietario
command.worlds.origin_shipped = incluso

command.intensity.current = Moltiplicatore di intensità attuale: {value}
command.intensity.set = Moltiplicatore di intensità impostato a {value}.
command.intensity.usage = Uso: /mobscaling intensity [moltiplicatore]. Un numero >= 0 (1.0 = neutrale, valori più alti = creature più difficili).
command.intensity.persist_hint = Modifica valida solo in tempo reale: per mantenerla dopo un riavvio, imposta la chiave Intensity in mods/MmoMobScaling/mob-scaling.json.
command.intensity.saved = Salvato: il moltiplicatore di intensità persiste ora tra i riavvii.

command.purge.start = Rimozione dei residui di ridimensionamento dalle creature caricate in questo mondo...
command.purge.done = Residui di ridimensionamento rimossi da {count} creature caricate.
command.inspect.header = Ridimensionamento delle creature nella tua posizione:
command.inspect.power = Il tuo livello di potere: {power}
command.inspect.world = Soglia minima di difficoltà del mondo: {floor} (ridimensionamento attivo: {enabled})
command.inspect.zone = Zona {zone}: soglia di base {base}, bonus distanza +{bonus}, soglia effettiva {floor}
command.inspect.region = Potere registrato della regione: {power} (modalità {mode}, giocatori registrati: {tracked})
command.inspect.difficulty = Difficoltà effettiva di comparsa qui: {difficulty}
command.inspect.chance = Probabilità di rarità alla comparsa: {chance}
command.inspect.curve = Curva delle statistiche per creatura comune qui: HP x{hp}, danno inflitto x{out}, danno subito x{in}

command.hud.usage = Uso: /mobscaling hud <zone|inspector> <on|off|POSITION> [offsetX] [offsetY]. Posizioni: TOP_LEFT, TOP_CENTER, TOP_RIGHT, CENTER_LEFT, CENTER, CENTER_RIGHT, BOTTOM_LEFT, BOTTOM_CENTER, BOTTOM_RIGHT.
command.hud.enabled = HUD attivato per tutti i giocatori: {target}
command.hud.disabled = HUD disattivato per tutti i giocatori: {target}
command.hud.moved = {target} riposizionato su {position} (scostamento {x}, {y}).
command.hud.persist_hint = Modifica valida solo in tempo reale: per mantenerla dopo un riavvio, imposta le chiavi ZoneHud/InspectorHud in mods/MmoMobScaling/mob-scaling.json.
command.hud.saved = Salvato: il cambio HUD persiste ora tra i riavvii.

command.hud.target.zone = HUD difficoltà zona
command.hud.target.inspector = HUD ispettore creature
command.arg.hud_target = Quale HUD: zone oppure inspector.
command.arg.hud_value = on, off, oppure un preset di posizione come TOP_LEFT.
command.arg.hud_offset_x = Scostamento in pixel opzionale dal bordo orizzontale ancorato.
command.arg.hud_offset_y = Scostamento in pixel opzionale dal bordo verticale ancorato.
command.arg.intensity = Il moltiplicatore di intensità (>= 0; 1.0 neutrale, valori più alti = creature più difficili). Ometti per mostrare il valore attuale.

hud.zone.title = DIFFICOLTÀ ZONA
